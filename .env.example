# Copia este archivo a .env y rellena tus credenciales.
# También lo usa docker-compose para inyectar variables.

# URL pública desde la que se accede a la app (sin slash final).
# Debe estar registrada en Google Cloud Console como redirect URI.
FRONTEND_URL=http://localhost:3001

# Puerto expuesto por el servidor (mapeo externo)
PORT=3001

# Credenciales de Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mismo redirect que en Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Al menos 32 bytes aleatorios. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Clave de cifrado de tokens OAuth (32 bytes en hex). Genera con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si se omite, se deriva de SESSION_SECRET (con un aviso).
TOKEN_ENCRYPTION_KEY=

# Opcional: para clasificar senders con Gemini
GEMINI_API_KEY=

# Tipo de entorno
NODE_ENV=production